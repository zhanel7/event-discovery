# Скопируйте в .env при локальном запуске без Docker (не коммитьте .env)

# PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/event_discovery

# Redis (кэш списка конференций + rate limit).
# При локальном стеке через docker compose Redis с хоста: порт 6380 (см. docker-compose.yml).
REDIS_URL=redis://localhost:6380/0

# JWT (в продакшене — длинная случайная строка, минимум 32 символа)
JWT_SECRET_KEY=change-me-to-a-long-random-secret-in-production

# CORS: одно значение
FRONTEND_ORIGIN=http://localhost:3000
# или несколько через запятую (имеет приоритет над FRONTEND_ORIGIN)
# FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Логи
LOG_FILE=logs/app.log

# Первый администратор (создаётся init_admin при старте, если email ещё нет в БД)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin12345

# TTL кэша списка конференций (секунды)
CONFERENCE_CACHE_TTL=60

# Vite (только при сборке фронтенда)
VITE_API_URL=http://localhost:8000
